{
  "name": "@diabolic/hangover",
  "version": "0.1.7",
  "description": "A headless-style, compound React dropdown/field-picker component library",
  "license": "MIT",
  "author": "bugrakaan",
  "keywords": [
    "react",
    "dropdown",
    "select",
    "field-picker",
    "compound-component",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bugrakaan/hangover.git"
  },
  "bugs": {
    "url": "https://github.com/bugrakaan/hangover/issues"
  },
  "homepage": "https://bugrakaan.github.io/hangover/",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/hangover.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "dist/hangover.css"
  ],
  "type": "module",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && rollup -c",
    "dev": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && rollup -c -w",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx}\"",
    "export": "node scripts/export-component.mjs",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^4.13.0",
    "rollup-plugin-scss": "^4.0.0",
    "sass": "^1.99.0",
    "storybook": "^10.4.6",
    "eslint-plugin-storybook": "10.4.6"
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  }
}
